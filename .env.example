# Backend HTTP server
BACKEND_PORT=3000

# MySQL database used by backend through Prisma.
# Use localhost for Prisma CLI commands from the host machine.
# Docker Compose injects an internal mysql hostname into the backend container.
# `prisma migrate dev` may need the root URL locally because it creates a shadow database.
MYSQL_PORT=3306
MYSQL_DATABASE=smart_scanner
MYSQL_USER=smart_scanner
MYSQL_PASSWORD=smart_scanner_password
MYSQL_ROOT_PASSWORD=smart_scanner_root_password
DATABASE_URL=mysql://smart_scanner:smart_scanner_password@localhost:3306/smart_scanner
MIGRATION_DATABASE_URL=mysql://root:smart_scanner_root_password@localhost:3306/smart_scanner

# OpenAI receipt extraction.
# Keep this key only in backend/server environments. Do not expose it to mobile.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_RECEIPT_EXTRACTION_MODEL=gpt-5-mini

# Container paths used by docker-compose.yml
UPLOADS_DIR=/uploads

# Runtime mode for local development/demo
NODE_ENV=development

# Mobile app API URL.
# Android emulator: http://10.0.2.2:3000
# Physical phone: http://YOUR_COMPUTER_LAN_IP:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
